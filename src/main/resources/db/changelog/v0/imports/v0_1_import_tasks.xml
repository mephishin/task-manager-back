<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="v0_1_import_tasks.xml" author=''>
        <loadData tableName="task" file="csv/tasks.csv" relativeToChangelogFile="true" separator=";">
            <column header="id" name="id"/>
            <column header="name" name="name"/>
            <column header="key" name="key"/>
            <column header="description" name="description"/>
            <column header="status" name="status"/>
            <column header="type" name="type"/>
        </loadData>
    </changeSet>
</databaseChangeLog>